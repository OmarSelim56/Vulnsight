# VulnSight Sensor Agent — environment configuration
# Copy this file to sensor/.env and fill in your values.

# -----------------------------------------------------------
# Required
# -----------------------------------------------------------

# Base URL of the VulnSight server (no trailing slash)
VS_SERVER_URL=https://ids.example.com

# Sensor API key — generate one in the VulnSight admin panel → Sensor API Keys
VS_SENSOR_KEY=vs_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------
# Optional
# -----------------------------------------------------------

# Human-readable name shown in the dashboard (defaults to hostname)
# VS_SENSOR_NAME=server-01

# Network interface to capture (defaults to first active interface / "any")
# VS_INTERFACE=eth0

# Paths to the model and scaler (relative to project root)
# VS_MODEL_PATH=model/vulnsight_cnn_bilstm.pth
# VS_SCALER_PATH=model/scaler.pkl

# Minimum confidence score [0.0–1.0] to report an alert (default: 0.5)
# VS_CONFIDENCE_MIN=0.5

# Set to 1 to also report benign (normal) flows (default: 0 = malicious only)
# VS_REPORT_BENIGN=0

# Number of alerts to buffer before a single flush to the server (default: 10)
# VS_BATCH_SIZE=10

# Number of POST retries on transient network error (default: 3)
# VS_RETRY_LIMIT=3
